# ============================================================
# Scientific output folders
# These are generated by running the experiments.
# They should NOT be tracked by git — they can be reproduced
# by running the scripts. If you want to archive specific
# results, copy them to a separate documented folder instead.
# ============================================================
test_christoffel/
error_charts_polynomial/
plot_christoffel_comparison/
g_k_projections/

# ============================================================
# Data and results files
# Large CSVs and pickle files should not be in the repo.
# Exception: if you have a small reference CSV for a paper
# table, move it to a documented results/ folder and
# un-ignore it explicitly with:  !results/my_table.csv
# ============================================================
*.csv
*.pkl
*.pickle
*.npy
*.npz

# ============================================================
# Figures generated by experiments
# Same reasoning as output folders above.
# ============================================================
*.png
*.pdf
*.eps
*.svg

# ============================================================
# OS and editor noise
# ============================================================
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# ============================================================
# pytest and coverage
# ============================================================
.pytest_cache/
.coverage
htmlcov/
main_christoffel.py
